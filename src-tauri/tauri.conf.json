{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STerm",
  "version": "0.2.0",
  "identifier": "com.while.sterm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "STerm",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEN0M3NkIyM0MwRUFEQzYKUldUR3JRNDhzblo4alZ4dVRCUHJzekJPUUgwUG9SaVdJT2hDcytnQStBdkY2UkxhN1FhMUxvN1AK",
      "endpoints": [
        "https://github.com/while-coder/STerm/releases/download/updater/latest.json"
      ]
    }
  }
}
